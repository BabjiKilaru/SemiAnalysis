{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "amber", "color": "#F7B041", "name": "SA Amber" },
        { "slug": "cobalt", "color": "#0B86D1", "name": "SA Cobalt" },
        { "slug": "mint", "color": "#2EAD8E", "name": "SA Mint" },
        { "slug": "coral", "color": "#E06347", "name": "SA Coral" },
        { "slug": "slate", "color": "#3D3D3D", "name": "SA Slate" },
        { "slug": "metal", "color": "#969696", "name": "SA Metal" },
        { "slug": "background", "color": "#0A0A0A", "name": "Background" },
        { "slug": "elevated", "color": "#141414", "name": "Elevated" },
        { "slug": "card", "color": "#1A1A1A", "name": "Card" },
        { "slug": "border", "color": "#2A2A2A", "name": "Border" },
        { "slug": "foreground", "color": "#F5F5F5", "name": "Foreground" },
        { "slug": "muted", "color": "#A3A3A3", "name": "Muted" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Outfit, system-ui, sans-serif",
          "slug": "outfit",
          "name": "Outfit"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "1.5rem", "name": "Extra Large" },
        { "slug": "xx-large", "size": "2.25rem", "name": "2X Large" },
        { "slug": "hero", "size": "3.75rem", "name": "Hero" }
      ]
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1152px"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--outfit)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.6"
    },
    "elements": {
      "link": {
        "color": { "text": "var(--wp--preset--color--cobalt)" }
      },
      "heading": {
        "typography": { "fontWeight": "700" }
      }
    },
    "blocks": {
      "core/button": {
        "border": { "radius": "9999px" },
        "color": {
          "background": "var(--wp--preset--color--amber)",
          "text": "#000000"
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": [
    { "name": "page-models", "title": "Models Hub", "postTypes": ["page"] },
    { "name": "single-sa_product", "title": "Product", "postTypes": ["sa_product"] }
  ]
}

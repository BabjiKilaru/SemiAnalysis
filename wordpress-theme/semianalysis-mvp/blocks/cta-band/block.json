    "secondaryUrl": { "type": "string", "default": "mailto:ChipBookSales@SemiAnalysis.com" },
    "tertiaryLabel": { "type": "string", "default": "Browse Models" },
    "tertiaryUrl": { "type": "string", "default": "/models/" }
